# Development Mode
# Set to 'true' to use mock data instead of API calls (for styling/development)
# Set to 'false' for production with real API calls
VITE_TEST_MODE=true

# Vapi.ai Configuration
# Get your public key from https://vapi.ai dashboard
# Vapi is used ONLY for voice transcription (Speech-to-Text)
# Your backend handles question generation and answer evaluation
VITE_VAPI_PUBLIC_KEY=your_vapi_public_key_here

# Optional: Vapi Assistant ID (if you created a custom assistant in Vapi dashboard)
VITE_VAPI_ASSISTANT_ID=

# Sentry Configuration for Error Tracking
VITE_SENTRY_DSN=https://your-dsn@sentry.io/your-project-id